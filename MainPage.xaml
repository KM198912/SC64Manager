<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NetGui.ViewModels"
             xmlns:models="clr-namespace:NetGui.Models"
             xmlns:conv="clr-namespace:NetGui.Converters"
             x:Class="NetGui.MainPage"
             BackgroundColor="#1a1a1a">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:ConnectionColorConverter x:Key="ConnectionColorConverter" />
            <conv:NotParentDirConverter x:Key="NotParentDirConverter" />
            <conv:IsNullConverter x:Key="IsNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Main Application Layout -->
        <Grid RowDefinitions="Auto, Auto, *, Auto" ColumnDefinitions="*, *" Padding="20" ColumnSpacing="20">

            <!-- Header -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" BackgroundColor="#252525" StrokeShape="RoundRectangle 8" Padding="15" Margin="0,0,0,10">
                <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                        <!-- Branding Logo with Link -->
                        <Image Source="sc64.png" 
                               WidthRequest="30" 
                               HeightRequest="30" 
                               VerticalOptions="Center"
                               ToolTipProperties.Text="Visit summercart64.dev">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLogoTapped" />
                            </Image.GestureRecognizers>
                        </Image>

                        <Label Text="SC64 Manager" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                        <Border BackgroundColor="{Binding StatusColor}" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Center">
                            <Label Text="{Binding StatusText}" FontSize="12" TextColor="Black" FontAttributes="Bold"/>
                        </Border>
                        <Border IsVisible="{Binding IsConnected}" BackgroundColor="#2c3e50" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Center">
                            <Label Text="{Binding StatusTextN64}" FontSize="12" TextColor="White" FontAttributes="Bold"/>
                        </Border>
                        <Border IsVisible="{Binding IsUpToDate}" BackgroundColor="#1b5e20" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Center">
                            <Label Text="LATEST" FontSize="10" TextColor="White" FontAttributes="Bold"/>
                        </Border>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Grid.Column="1" Spacing="10" Margin="0,0,20,0" VerticalOptions="Center">
                        <Label Text="COM Port:" VerticalOptions="Center" TextColor="#cccccc"/>
                        <Picker ItemsSource="{Binding AvailablePorts}" 
                                SelectedItem="{Binding SelectedPort}"
                                WidthRequest="120"
                                TextColor="White"
                                BackgroundColor="#333333"/>
                        <Button Text="🔄" Command="{Binding RefreshAvailablePortsCommand}" BackgroundColor="Transparent"/>
                        <Button Text="🐚 Debug" 
                                Command="{Binding OpenDebugConsoleCommand}" 
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                BackgroundColor="#2c3e50" 
                                TextColor="White" 
                                FontSize="12" 
                                HeightRequest="32"
                                Padding="10,0"
                                ToolTipProperties.Text="Launch External Debug Console"/>
                    </HorizontalStackLayout>

                    <ActivityIndicator Grid.Column="2" IsRunning="{Binding IsBusy}" Color="#0078d4" WidthRequest="30" Margin="0,0,10,0"/>

                    <Button Grid.Column="3" 
                            Text="{Binding ConnectionButtonText}" 
                            Command="{Binding ToggleConnectionCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            BackgroundColor="{Binding IsConnected, Converter={StaticResource ConnectionColorConverter}}"
                            TextColor="White" 
                            FontAttributes="Bold" 
                            WidthRequest="120" />
                </Grid>
            </Border>

            <!-- Banners Section -->
            <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="0">
                <!-- Update Banner -->
                <Border IsVisible="{Binding UpdateAvailable}" 
                        BackgroundColor="#332a00" Stroke="#ffd700" StrokeThickness="1" 
                        StrokeShape="RoundRectangle 8" Padding="15" Margin="0,0,0,10">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Label Text="✨" FontSize="20" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0">
                            <Label Text="Firmware Update Available!" FontAttributes="Bold" TextColor="#ffd700" FontSize="14"/>
                            <Label Text="{Binding LatestVersionTag, StringFormat='Version {0} is now available on GitHub.'}" TextColor="#bbbbbb" FontSize="12"/>
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="Update Now ⚡" Command="{Binding GoToUpdateCommand}" 
                                BackgroundColor="#ffd700" TextColor="Black" FontAttributes="Bold" Padding="20,0"/>
                    </Grid>
                </Border>
    
                <!-- Power Safety Banner -->
                <Border IsVisible="{Binding IsN64PoweredOn}" 
                        BackgroundColor="#3c1b00" Stroke="#ff8c00" StrokeThickness="1" 
                        StrokeShape="RoundRectangle 8" Padding="15" Margin="0,0,0,10">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Text="⚠️" FontSize="20" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0">
                            <Label Text="N64 is Powered On" FontAttributes="Bold" TextColor="#ff8c00" FontSize="14"/>
                            <Label Text="SD Card modifications are restricted while the console is energized for hardware safety." TextColor="#bbbbbb" FontSize="12"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Local Files -->
            <Grid Grid.Row="2" Grid.Column="0" RowDefinitions="Auto, Auto, *">
                <HorizontalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,10">
                    <Label Text="Local Workstation" FontSize="16" FontAttributes="Bold" TextColor="#0078d4" VerticalOptions="Center"/>
                    <Label Text="{Binding CurrentLocalPath}" TextColor="#888888" VerticalOptions="Center" FontSize="13" LineBreakMode="HeadTruncation"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Row="1" Spacing="10" Margin="0,0,0,10">
                    <Button Text="Refresh" Command="{Binding RefreshLocalFilesCommand}" 
                            BackgroundColor="#008080" TextColor="White" Padding="15,0" HeightRequest="36" />
                </HorizontalStackLayout>
                
                <Border Grid.Row="2" BackgroundColor="#252525" StrokeShape="RoundRectangle 8">
                    <CollectionView ItemsSource="{Binding LocalFiles}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:FileItem">
                                <Grid ColumnDefinitions="30, *, Auto, 40" Padding="10,5">
                                    <Label Text="&#xED25;" FontFamily="Segoe MDL2 Assets" IsVisible="{Binding IsDirectory}" VerticalOptions="Center" TextColor="#FFD700">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=NavigateLocalCommand}" CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label Grid.Column="1" Text="{Binding Name}" TextColor="White" VerticalOptions="Center" Margin="5,0,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=NavigateLocalCommand}" CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label Grid.Column="2" Text="{Binding SizeDisplay}" TextColor="#888888" VerticalOptions="Center" FontSize="12" Margin="0,0,5,0"/>
                                    
                                    <Button Grid.Column="3" Text="&#xE111;" FontFamily="Segoe MDL2 Assets" 
                                            IsVisible="{Binding IsDirectory, Converter={StaticResource InverseBoolConverter}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=UploadLocalFileItemCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=CanModifyRemoteFs}"
                                            BackgroundColor="Transparent" TextColor="#FFD700"
                                            Padding="0" WidthRequest="30" HeightRequest="25" FontSize="14"
                                            ToolTipProperties.Text="Upload to SD"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </Grid>

            <!-- Remote Files -->
            <Grid Grid.Row="2" Grid.Column="1" RowDefinitions="Auto, Auto, *">
                <HorizontalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,5">
                    <Label Text="SummerCart64 SD" FontSize="16" FontAttributes="Bold" TextColor="#4caf50" VerticalOptions="Center"/>
                    <Label Text="{Binding CurrentRemotePath}" TextColor="#888888" VerticalOptions="Center" FontSize="13" IsVisible="{Binding IsSdMounted}"/>
                </HorizontalStackLayout>
                
                <!-- SD Not Mounted Placeholder -->
                <Border Grid.Row="1" Grid.RowSpan="2" IsVisible="{Binding IsSdMounted, Converter={StaticResource InverseBoolConverter}}"
                        BackgroundColor="#252525" StrokeShape="RoundRectangle 8" Margin="0,10,0,0">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20" Padding="40">
                        <Label Text="📤" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="SD Card Not Mounted" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="Filesystem access must be manually established." TextColor="#888" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        
                        <Button Text="Mount SD Card" 
                                Command="{Binding MountSdCommand}"
                                IsEnabled="{Binding IsConnected}"
                                IsVisible="{Binding IsN64PoweredOn, Converter={StaticResource InverseBoolConverter}}"
                                BackgroundColor="#4caf50" TextColor="White" 
                                FontAttributes="Bold" Padding="30,10" CornerRadius="8"/>
                        
                        <Label IsVisible="{Binding IsN64PoweredOn}" 
                               Text="⚠️ SD Management Restricted" FontAttributes="Bold" TextColor="#ff8c00" HorizontalOptions="Center"/>
                        <Label IsVisible="{Binding IsN64PoweredOn}" 
                               Text="Power OFF the N64 console to enable filesystem access." TextColor="#bbbbbb" FontSize="12" HorizontalOptions="Center"/>

                        <Label IsVisible="{Binding IsConnected, Converter={StaticResource InverseBoolConverter}}" 
                               Text="(Connect to hardware first)" TextColor="#c62828" FontSize="12" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Remote Controls (Visible when mounted) -->
                <HorizontalStackLayout Grid.Row="1" Spacing="10" Margin="0,0,0,10" IsVisible="{Binding IsSdMounted}">
                    <Button Text="Upload" Command="{Binding UploadFileCommand}" 
                            IsEnabled="{Binding CanModifyRemoteFs}"
                            BackgroundColor="#0078d4" TextColor="White" Padding="15,0" HeightRequest="36" />
                    <Button Text="New Folder" Command="{Binding CreateRemoteFolderCommand}" 
                            IsEnabled="{Binding CanModifyRemoteFs}"
                            BackgroundColor="#607d8b" TextColor="White" Padding="10,0" HeightRequest="36" />
                    <Button Text="Refresh" Command="{Binding RefreshRemoteFilesCommand}" 
                            IsEnabled="{Binding IsConnected}"
                            BackgroundColor="#008080" TextColor="White" Padding="15,0" HeightRequest="36" />
                    <Button Text="Unmount" Command="{Binding UnmountSdCommand}" 
                            IsEnabled="{Binding IsSdMounted}"
                            BackgroundColor="#2c3e50" TextColor="White" Padding="15,0" HeightRequest="36" />
                    <Button Text="Scrape All" Command="{Binding ScrapeBoxArtCommand}" 
                            IsEnabled="{Binding IsSdMounted}"
                            BackgroundColor="#673ab7" TextColor="White" Padding="15,0" HeightRequest="36" 
                            ToolTipProperties.Text="Identify ROMs and download official box art"/>
                    <Button Text="Scrape Selected" Command="{Binding ScrapeSelectedCommand}" 
                            IsEnabled="{Binding IsSdMounted}"
                            BackgroundColor="#512da8" TextColor="White" Padding="15,0" HeightRequest="36" 
                            ToolTipProperties.Text="Identify and scrape only checked items"/>
                    <Button Text="Delete" Command="{Binding DeleteSelectedCommand}" 
                            IsEnabled="{Binding CanModifyRemoteFs}"
                            BackgroundColor="#c62828" TextColor="White" Padding="15,0" HeightRequest="36" />
                </HorizontalStackLayout>

                <Border Grid.Row="2" BackgroundColor="#252525" StrokeShape="RoundRectangle 8" IsVisible="{Binding IsSdMounted}">
                    <CollectionView ItemsSource="{Binding RemoteFiles}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:FileItem">
                                <Grid ColumnDefinitions="30, 25, *, Auto, Auto, Auto, Auto, Auto, Auto" Padding="10,5">
                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalOptions="Center" 
                                              IsVisible="{Binding Name, Converter={StaticResource NotParentDirConverter}}"/>
                                    
                                    <Grid Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center">
                                        <!-- Folder Icon -->
                                        <Label Text="&#xED25;" FontFamily="Segoe MDL2 Assets" 
                                               IsVisible="{Binding IsDirectory}" 
                                               TextColor="#FFD700">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=NavigateRemoteCommand}" CommandParameter="{Binding .}"/>
                                            </Label.GestureRecognizers>
                                        </Label>

                                        <!-- Box Art Thumbnail (if available) -->
                                        <Border IsVisible="{Binding BoxArtPath, Converter={StaticResource IsNullConverter}, ConverterParameter=invert}"
                                                WidthRequest="24" HeightRequest="24" StrokeShape="RoundRectangle 2" StrokeThickness="1" Stroke="#ffd700">
                                            <Image Source="{Binding BoxArtPath}" Aspect="AspectFill" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ShowBoxArtPreviewCommand}" CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Border>

                                        <!-- File Icon (fallback if no box art) -->
                                        <Label Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" 
                                               IsVisible="{Binding BoxArtPath, Converter={StaticResource IsNullConverter}}" 
                                               TextColor="#E0E0E0">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsDirectory}" Value="True">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                    
                                    <Label Grid.Column="2" Text="{Binding Name}" TextColor="White" VerticalOptions="Center" Margin="5,0,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=NavigateRemoteCommand}" CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
 
                                    <Label Grid.Column="3" Text="{Binding SizeDisplay}" TextColor="#888888" VerticalOptions="Center" FontSize="12" Margin="0,0,10,0"/>
 
                                    <Button Grid.Column="4" Text="&#xE945;" FontFamily="Segoe MDL2 Assets" 
                                            IsVisible="{Binding IsDirectory, Converter={StaticResource InverseBoolConverter}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=SetAsDefaultBootRomCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=CanModifyRemoteFs}"
                                            BackgroundColor="Transparent" TextColor="#FFD700"
                                            Padding="0" WidthRequest="30" HeightRequest="25" FontSize="14"
                                            ToolTipProperties.Text="Set as Default Boot ROM (Autoload)"/>

                                    <Button Grid.Column="5" Text="&#xE13E;" FontFamily="Segoe MDL2 Assets" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RenameRemoteFileCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=CanModifyRemoteFs}"
                                            BackgroundColor="Transparent" TextColor="#FFD700"
                                            Padding="0" WidthRequest="30" HeightRequest="25" FontSize="14"
                                            ToolTipProperties.Text="Rename"/>
 
                                    <Button Grid.Column="6" Text="&#xE8DE;" FontFamily="Segoe MDL2 Assets" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=MoveRemoteFileCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=CanModifyRemoteFs}"
                                            BackgroundColor="Transparent" TextColor="#2196f3"
                                            Padding="0" WidthRequest="30" HeightRequest="25" FontSize="14"
                                            ToolTipProperties.Text="Move to..."/>
 
                                    <Button Grid.Column="7" Text="&#xE112;" FontFamily="Segoe MDL2 Assets" 
                                            IsVisible="{Binding IsDirectory, Converter={StaticResource InverseBoolConverter}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DownloadRemoteFileItemCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=CanModifyRemoteFs}"
                                            BackgroundColor="Transparent" TextColor="#4caf50"
                                            Padding="0" WidthRequest="30" HeightRequest="25" FontSize="14"
                                            ToolTipProperties.Text="Quick Download to PC"/>
 
                                    <Button Grid.Column="8" Text="&#xE118;" FontFamily="Segoe MDL2 Assets" 
                                            IsVisible="{Binding IsDirectory, Converter={StaticResource InverseBoolConverter}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DownloadFileCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=CanModifyRemoteFs}"
                                            BackgroundColor="Transparent" BorderColor="#444444" BorderWidth="1"
                                            Padding="0" WidthRequest="30" HeightRequest="25" FontSize="12" TextColor="White"
                                            ToolTipProperties.Text="Save As..."/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </Grid>

            <!-- Status Log -->
            <Grid Grid.Row="3" Grid.ColumnSpan="2" HeightRequest="150" Margin="0,20,0,0">
                <Border BackgroundColor="#111111" StrokeThickness="1" Stroke="#333333">
                    <Grid>
                        <ScrollView x:Name="LogScrollView" Padding="10">
                            <Label x:Name="LogLabel" Text="{Binding LogText}" TextColor="#00ff00" FontFamily="Consolas" FontSize="12"/>
                        </ScrollView>
                        
                        <!-- Floating Log Tools -->
                        <HorizontalStackLayout HorizontalOptions="End" VerticalOptions="Start" Padding="10" Spacing="10">
                            <Button Text="&#xE16F;" FontFamily="Segoe MDL2 Assets" 
                                    Command="{Binding CopyLogsCommand}"
                                    BackgroundColor="#222222" TextColor="White" 
                                    WidthRequest="35" HeightRequest="35" FontSize="14"
                                    ToolTipProperties.Text="Copy Logs"/>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Fullscreen Progress Overlay -->
        <Border IsVisible="{Binding IsBusy}" BackgroundColor="#CC000000" StrokeThickness="0">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                <Border BackgroundColor="#2a2a2a" Padding="40" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#444444">
                    <VerticalStackLayout Spacing="15" WidthRequest="400">
                        <Label Text="Hardware Operation in Progress" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="{Binding CurrentFileName}" FontSize="15" TextColor="#FFD700" FontAttributes="Italic" HorizontalOptions="Center" Margin="0,0,0,5"/>
                        <Label Text="{Binding ProgressText}" FontSize="13" TextColor="#aaaaaa" HorizontalOptions="Center" Margin="0,0,0,10"/>
                        
                        <ProgressBar Progress="{Binding ProgressValue}" HeightRequest="12" ProgressColor="#0078d4" BackgroundColor="#1a1a1a"/>
                        
                        <Grid ColumnDefinitions="*, *">
                            <Label Grid.Column="1" Text="{Binding ProgressValue, StringFormat='{0:P0}'}" FontSize="12" TextColor="#0078d4" FontAttributes="Bold" HorizontalOptions="End"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Border>

        <!-- Box Art Preview Overlay -->
        <Border IsVisible="{Binding CurrentBoxArtPreview, Converter={StaticResource IsNullConverter}, ConverterParameter=invert}"
                BackgroundColor="#EE000000" StrokeThickness="0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseBoxArtPreviewCommand}" />
            </Border.GestureRecognizers>
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                <Border BackgroundColor="#2a2a2a" Padding="20" StrokeShape="RoundRectangle 12" StrokeThickness="2" Stroke="#ffd700" WidthRequest="900">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Header / Close -->
                        <Button Grid.Row="0" Text="&#xE106;" FontFamily="Segoe MDL2 Assets" 
                                Command="{Binding CloseBoxArtPreviewCommand}"
                                BackgroundColor="#c62828" TextColor="White" 
                                WidthRequest="32" HeightRequest="32" CornerRadius="16"
                                HorizontalOptions="End" VerticalOptions="Start" Margin="0,0,0,10" />

                        <Grid Grid.Row="1" ColumnDefinitions="Auto, *" ColumnSpacing="30">
                            <!-- Left: Image -->
                            <Image Grid.Column="0" Source="{Binding CurrentBoxArtPreview}" 
                                   HeightRequest="400" WidthRequest="500" Aspect="AspectFit" />
                            
                            <!-- Right: Description -->
                            <VerticalStackLayout Grid.Column="1" Spacing="15" 
                                                 IsVisible="{Binding CurrentDescription, Converter={StaticResource IsNullConverter}, ConverterParameter=invert}">
                                <Label Text="Description" FontSize="22" FontAttributes="Bold" TextColor="#ffd700" />
                                <Border BackgroundColor="#111111" Padding="15" StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#444444">
                                    <ScrollView HeightRequest="320">
                                        <Label Text="{Binding CurrentDescription}" FontSize="16" LineHeight="1.4" TextColor="White" />
                                    </ScrollView>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Fallback if no description -->
                            <Label Grid.Column="1" Text="No description available for this ROM." 
                                   VerticalOptions="Center" HorizontalOptions="Center" TextColor="#666"
                                   IsVisible="{Binding CurrentDescription, Converter={StaticResource IsNullConverter}}" />
                        </Grid>
                    </Grid>
                </Border>
                <Label Text="Click anywhere to close" TextColor="#aaaaaa" HorizontalOptions="Center" FontSize="14" />
            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentPage>
