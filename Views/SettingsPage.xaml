<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:NetGui.Converters"
             x:Class="NetGui.Views.SettingsPage"
             BackgroundColor="#1a1a1a"
             Title="Settings">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            <Label Text="Application Settings"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White" />

            <BoxView HeightRequest="1" BackgroundColor="#333333" />

            <!-- functional settings -->
            <VerticalStackLayout Spacing="10" Margin="0,20">
                <Label Text="Default ROM Directory" TextColor="#aaaaaa" />
                <Grid ColumnDefinitions="*, Auto">
                    <Border BackgroundColor="#252525" Stroke="#333333" Padding="10">
                        <Label Text="{Binding DefaultRomPath}" TextColor="White" />
                    </Border>
                    <Button Grid.Column="1" Text="Browse" Command="{Binding BrowseLocalPathCommand}" Margin="10,0,0,0" />
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Default Firmware Directory" TextColor="#aaaaaa" />
                <Grid ColumnDefinitions="*, Auto">
                    <Border BackgroundColor="#252525" Stroke="#333333" Padding="10">
                        <Label Text="{Binding DefaultFirmwarePath}" TextColor="White" />
                    </Border>
                    <Button Grid.Column="1" Text="Browse" Command="{Binding BrowseFirmwarePathCommand}" Margin="10,0,0,0" />
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="SC64 Deployer Executable" TextColor="#aaaaaa" />
                <Grid ColumnDefinitions="*, Auto">
                    <Border BackgroundColor="#252525" Stroke="#333333" Padding="10">
                        <Label Text="{Binding DeployerPath}" TextColor="White" />
                    </Border>
                    <Button Grid.Column="1" Text="Browse" Command="{Binding BrowseDeployerPathCommand}" Margin="10,0,0,0" />
                </Grid>
            </VerticalStackLayout>
            
            <Label Text="* Settings are saved automatically upon selection." 
                   FontSize="12" 
                   TextColor="#666666" 
                   Margin="0,10,0,10"/>

            <BoxView HeightRequest="1" BackgroundColor="#333333" />

            <!-- SC64 Customization Section -->
            <VerticalStackLayout Spacing="15" Margin="0,10,0,0">
                <Label Text="SummerCart64 Customization"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#4caf50" />
                
                <Border BackgroundColor="#252525" Stroke="#333333" Padding="20" StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Menu Background Music" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            <Border BackgroundColor="#333" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Center">
                                <Label Text="{Binding MusicStatus}" FontSize="11" TextColor="#FFD700"/>
                            </Border>
                        </HorizontalStackLayout>
                        
                        <Label Text="Target: /menu/bg.mp3 (TheLeggett Custom Menu Compatible)" TextColor="#888" FontSize="12"/>
                        
                        <HorizontalStackLayout Spacing="10">
                            <Button Text="Set Custom Music (.mp3)" 
                                    Command="{Binding SetMenuMusicCommand}"
                                    IsEnabled="{Binding IsSdMounted}"
                                    BackgroundColor="#4caf50" TextColor="White" Padding="15,0" HeightRequest="36"/>
                            
                            <Button Text="Remove Music" 
                                    Command="{Binding RemoveMenuMusicCommand}"
                                    IsEnabled="{Binding IsSdMounted}"
                                    BackgroundColor="#c62828" TextColor="White" Padding="15,0" HeightRequest="36"/>
                        </HorizontalStackLayout>

                        <Label IsVisible="{Binding IsSdMounted, Converter={StaticResource InverseBoolConverter}}" 
                               Text="⚠️ SD card must be mounted to manage music (Mount in File Manager)." 
                               TextColor="#ccaa00" FontSize="11" FontAttributes="Italic"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- TheGamesDB Metadata Section -->
            <VerticalStackLayout Spacing="15" Margin="0,10,0,0">
                <Label Text="Metadata Providers"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#2196f3" />
                
                <Border BackgroundColor="#252525" Stroke="#333333" Padding="20" StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Enable TheGamesDB Fallback" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            <Switch Grid.Column="1" IsToggled="{Binding MetadataFallbackEnabled}" />
                        </Grid>

                        <Label Text="Primary: GitHub Repo. Fallback: TheGamesDB API (Requires Key)." TextColor="#888" FontSize="11"/>

                        <VerticalStackLayout Spacing="5" IsVisible="{Binding MetadataFallbackEnabled}">
                            <Label Text="TheGamesDB API Key" TextColor="#aaaaaa" FontSize="12"/>
                            <Entry Text="{Binding GamesDbApiKey}" Placeholder="Paste API Key here" BackgroundColor="#111" TextColor="White"/>
                            
                            <Button Text="Test Connection" 
                                    Command="{Binding TestGamesDbConnectionCommand}"
                                    BackgroundColor="#2196f3" TextColor="White" Margin="0,10,0,0"/>
                            
                            <Label Text="Find your key at thegamesdb.net (User Profile > API Key)" 
                                   TextColor="#666" FontSize="10" HorizontalOptions="Center" Margin="0,5,0,0"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
